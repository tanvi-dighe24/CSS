/* descendent selector( ) */
#img_container img{
    height: 200px;
    width: 200px;
}

/* child selector(>) */
#img_container>img{
    border: 10px solid blue;
}  

/* Adjecent sibling selector(+) */
p+button{
    background-color: darkgray;
}

/* General sibling selector(~) */
p~button{
    border: 2px solid red;
} 
