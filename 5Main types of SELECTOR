5 types of SELECTOR in CSS:
1) ID
2)Class 
3)Element
4)Univerrsal


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SIMPLE SELECTORS</title>
    <link rel="stylesheet" href="./simple.css">
</head>
<body>
    <!-- http://1.id selector(#) : to target an element uniquely  -->
    <h2 id="demo">Today was the great day.....</h2>

    <!--2.class selector(.) : to target multiple elements with same classname/ we can pass multiple classnames for single element  -->
    <p class="para para1 data">Lorem ipsum dolor sit amet.</p>
    <p class="para">Lorem ipsum dolor sit amet.</p>
    <p class="para">Lorem ipsum dolor sit amet.</p>
    <p class="para">Lorem ipsum dolor sit amet.</p>

    <!-- 3.element selector(tagname) -->
    <button>click</button>
    <button>click</button>


    
</body>
</html> 
