#...

.box{
    height: 100px;
    width: 100px;
}

/* static : default value (doesnot have any effect) */
.box1{
    background-color: red;
    position: static;
    left: 200px;
}

/* relative : element starts moving from its current position and it will not allow other elements to sit in their position so white space will be created */
.box2{
    background-color: yellowgreen;
    position: relative;
    left: 200px;
    top: 100px;
}

/* absolute : element  starts moving the from its root element and it will allow other elements to sit ni their position so white space will not be created */
.box3{
    background-color: blue;
    position: absolute;
    top: 200px;
    left: 200px;
}

/* fixed : element will take the specified position and it will be fixed over tht position , won't be scrollable */
.box4{
    background-color: yellow;
    position: fixed;
    left: 300px;
    top: 400px;
}

/* sticky : it will be scrollable until it reaches specified position  */
.box5{
    background-color: black;
    position: sticky;
    top: 20px;
} 
